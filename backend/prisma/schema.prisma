generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  jabatan   String?
  instansi  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistories StatusHistory[]
}

model Report {
  id            String   @id @default(uuid())
  reportNumber  String   @unique
  text          String
  reporterName  String?
  photoUrls     String[]

  kabupatenKota String
  kecamatan     String
  detailLokasi  String?
  latitude      Float?
  longitude     Float?

  categories    String[]
  urgensi       String?
  urgencyScore  Float?
  priorityScore Float?
  clusterId     String?

  status         ReportStatus @default(DITERIMA)
  disposisiDinas String?
  catatanAdmin   String?
  source         String       @default("form_warga")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistories StatusHistory[]
}

model StatusHistory {
  id        String       @id @default(uuid())
  reportId  String
  report    Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  status    ReportStatus
  note      String?
  changedBy String?
  user      User?        @relation(fields: [changedBy], references: [id])
  createdAt DateTime     @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum ReportStatus {
  DITERIMA
  DIANALISIS
  DIDISPOSISI
  DITINDAKLANJUTI
  SELESAI
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}